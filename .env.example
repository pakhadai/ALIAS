# ALIAS — example environment (copy to `.env` or use package-specific files; never commit secrets)
# Server: see also packages/server/.env.example

# Client (Vite) — place in packages/client/.env for local dev
# VITE_SENTRY_DSN=

# Server
# SENTRY_DSN=
#
# Admin security: optional IP/CIDR whitelist (VPN/WireGuard).
# Comma-separated list, e.g. `127.0.0.1,::1,10.8.0.0/24`. Leave empty to disable locally.
# ADMIN_ALLOWED_IPS=
#
# Admin security: allowed admin emails (comma-separated). In production this should be set.
# Example: ADMIN_ALLOWED_EMAILS=owner@example.com
# ADMIN_ALLOWED_EMAILS=

# Client production build: source map upload to Sentry (only when SENTRY_AUTH_TOKEN is set; also set SENTRY_ORG + SENTRY_PROJECT)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
