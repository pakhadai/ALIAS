# ALIAS Server — Local Development
# Copy to .env and fill in values (never commit .env!)

PORT=3001
NODE_ENV=development
# Unique per replica when scaling horizontally (shown in /health and Redis room writer keys)
# INSTANCE_ID=alias-api-1
# Cross-node game:action relay (Redis pub/sub). Set 0 or false to disable.
# ROOM_ACTION_RELAY=1
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://alias:alias_dev@localhost:5432/alias?schema=public

JWT_SECRET=dev-secret-change-me
CORS_ORIGIN=http://localhost:5173

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Stripe (test keys from Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=http://localhost:5173/?purchase=success
STRIPE_CANCEL_URL=http://localhost:5173/?purchase=cancelled

# VAPID keys for push notifications (optional)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@aliasmaster.app

# Sentry (optional — server error reporting)
# SENTRY_DSN=

# --- Admin API (/api/admin/*) — детально в кореневому README.md ---
# Static key: header x-admin-key must match (no JWT). Leave unset to use JWT only.
# ADMIN_API_KEY=
# Comma-separated emails allowed as admins when JWT user.email matches (no DB isAdmin required).
# ADMIN_ALLOWED_EMAILS=
# Optional IP/CIDR allowlist for admin routes (VPN). Empty = disabled.
# ADMIN_ALLOWED_IPS=
# Trust X-Forwarded-For from N proxies (production default in code: 1 if unset)
# TRUST_PROXY_HOPS=1

# --- Scaling / relay (see README) ---
# ROOM_ACTION_RELAY=1
# INSTANCE_ID=alias-api-1
