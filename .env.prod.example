# ALIAS — Production Environment Variables
# Copy to .env.prod and fill in all values

# Server / domain
DOMAIN=alias.yourdomain.com
SSL_EMAIL=admin@yourdomain.com

# Database
POSTGRES_DB=alias
POSTGRES_USER=alias
POSTGRES_PASSWORD=change_me_strong_password

# Security
JWT_SECRET=change_me_very_long_random_string_at_least_32_chars
# Admin security: allow admin API only from VPN/WireGuard IPs or subnets.
# Example for WireGuard subnet: 10.8.0.0/24
# ADMIN_ALLOWED_IPS=10.8.0.0/24,127.0.0.1,::1
# Admin security: allow admin API only for these email accounts (comma-separated).
# ADMIN_ALLOWED_EMAILS=owner@yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=

# Stripe (optional — for paid content)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry (optional)
# Client bundle (Vite) — browser SDK
# VITE_SENTRY_DSN=
# Server / Node
# SENTRY_DSN=
# Upload client source maps during `vite build` (omit locally). When set, also set SENTRY_ORG and SENTRY_PROJECT.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ── docker-compose.npm.yml (Nginx Proxy Manager на хості) ──
# Повний публічний origin (браузер + CORS), наприклад https://alias.example.com
# CORS_ORIGIN=https://alias.example.com
# VITE_SERVER_URL=https://alias.example.com
# Порт на хості для NPM forward (за замовчуванням 127.0.0.1:9080 → gateway:80)
# GATEWAY_PUBLISH=127.0.0.1:9080
